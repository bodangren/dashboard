@@ -32,12 +48,73 @@ func (lw *LogWatcher) Start() {
 
 func (lw *LogWatcher) Stop() {
 	close(lw.stop)
+	if lw.inotifyFd != -1 {
+		syscall.Close(lw.inotifyFd)
+	}
